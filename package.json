{
  "name": "@unbound/unbound",
  "private": true,
  "version": "0.0.20",
  "packageManager": "pnpm@9.0.6",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "desktop#dev": "turbo run dev --filter=desktop",
    "desktop:dev": "pnpm --filter @unbound/desktop tauri:dev",
    "desktop:build": "pnpm --filter @unbound/desktop build",
    "desktop:bundle": "pnpm --filter @unbound/desktop tauri:build",
    "web#dev": "turbo run dev --filter=web",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "gen-types": "turbo run gen-types --filter=database",
    "gen-types-local": "turbo run gen-types-local --filter=database",
    "database#start": "turbo run database#start",
    "database#stop": "turbo run database#stop",
    "database#status": "turbo run database#status",
    "release:patch": "tsx scripts/release/add-release.ts patch",
    "release:minor": "tsx scripts/release/add-release.ts minor",
    "release:major": "tsx scripts/release/add-release.ts major",
    "release:dispatch": "node scripts/release/dispatch-release-build.mjs",
    "daemon:build": "cd apps/daemon && cargo build --workspace --release",
    "daemon:start": "./apps/daemon/target/release/unbound-daemon start &",
    "daemon:foreground": "RUST_LOG=debug ./apps/daemon/target/release/unbound-daemon start --foreground",
    "daemon:foreground:trace": "RUST_LOG=trace ./apps/daemon/target/release/unbound-daemon start --foreground",
    "daemon:stop": "./apps/daemon/target/release/unbound-daemon stop",
    "daemon:status": "./apps/daemon/target/release/unbound-daemon status",
    "daemon:dev": "./scripts/dev-daemon.sh",
    "daemon:dev:app": "./scripts/dev-daemon.sh --app",
    "daemon:dev:app:stop": "./scripts/dev-daemon-stop.sh",
    "signoz:start": "./scripts/signoz.sh start",
    "signoz:stop": "./scripts/signoz.sh stop",
    "signoz:status": "./scripts/signoz.sh status",
    "cli:build": "cd apps/cli-new && cargo build --release",
    "cli": "./apps/cli-new/target/release/unbound-cli"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "tsx": "^4.19.2",
    "turbo": "^2.8.10",
    "ultracite": "7.2.3"
  }
}
