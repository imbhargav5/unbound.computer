SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# Optional compile-time override for daemon web API calls (defaults to https://unbound.computer)
UNBOUND_WEB_APP_URL=

# Groq API key for session title generation (yamcha crate)
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=

# Runtime observability (daemon/cli)
UNBOUND_ENV=dev
UNBOUND_LOG_LEVEL=debug
UNBOUND_LOG_FORMAT=pretty
UNBOUND_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Comma-separated key=value headers
# UNBOUND_OTEL_HEADERS=authorization=Bearer <token>,x-api-key=<key>
UNBOUND_OTEL_SAMPLER=always_on
UNBOUND_OTEL_TRACES_SAMPLER_ARG=1.0
