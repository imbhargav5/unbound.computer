# Unbound Daemon Environment Configuration
#
# Copy this file to .env.local and fill in values for local development.
#
# Precedence (highest wins):
#   1. Runtime env var (set by DaemonLauncher or shell)
#   2. Config file (~/.unbound-dev/config.json)
#   3. Compile-time default (option_env!() baked into binary via .env.local)
#   4. No fallback — daemon will error if SUPABASE_URL / SUPABASE_PUBLISHABLE_KEY are missing
#
# The Xcode "Build Daemon" phase sources .env.local at compile time.
# DaemonLauncher.swift also passes the macOS app's Config values as
# runtime env vars, so the daemon always gets the correct config.

# Supabase project config
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Web app URL for social login, Ably token requests, and billing API calls
# Defaults to http://localhost:3000 in dev
UNBOUND_WEB_APP_URL=

# Groq API key for session title generation (yamcha crate)
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=

# Runtime observability (daemon/cli)
UNBOUND_ENV=dev
UNBOUND_LOG_LEVEL=debug
UNBOUND_LOG_FORMAT=pretty
UNBOUND_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Comma-separated key=value headers
# UNBOUND_OTEL_HEADERS=authorization=Bearer <token>,x-api-key=<key>
UNBOUND_OTEL_SAMPLER=always_on
UNBOUND_OTEL_TRACES_SAMPLER_ARG=1.0

# Presence Durable Object heartbeat (optional)
# UNBOUND_PRESENCE_DO_HEARTBEAT_URL=
# UNBOUND_PRESENCE_DO_TOKEN=
# UNBOUND_PRESENCE_DO_TTL_MS=12000
