{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Unbound",
  "version": "0.0.20",
  "identifier": "com.unbound.desktop",
  "build": {
    "beforeDevCommand": "./scripts/ensure-dev-server.sh",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Unbound",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "DeveloperTool"
  }
}
